{
    "name": "libxa/socket",
    "description": "Standalone WebSocket server for LibxaFrame (Workerman-powered), with multi-app registration and signed private/presence channel authorization — inspired by Laravel Reverb.",
    "type": "library",
    "license": "MIT",
    "keywords": ["libxa", "libxaframe", "websocket", "realtime", "workerman", "reverb"],
    "require": {
        "php": "^8.3",
        "libxa/framework": "^0.8.0",
        "workerman/workerman": "^4.1",
        "symfony/console": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "LibxaSocket\\": "src/"
        }
    },
    "extra": {
        "Libxa": {
            "providers": [
                "LibxaSocket\\SocketServiceProvider"
            ]
        }
    }
}
